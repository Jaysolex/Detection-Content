// DETECTION: Script Execution from High-Risk Folders
// MITRE: T1059 (Command and Scripting Interpreter)

SecurityEvent
| where EventID == 4688
| where Process has_any ("powershell.exe", "cscript.exe", "wscript.exe")
| where CommandLine has_any ("Downloads", "Desktop", "Temp", "AppData\\Local\\Temp")
| project TimeGenerated, Computer, Account, Process, CommandLine

// WHAT THIS DETECTS: PowerShell/VBScript from Downloads/Desktop/Temp
// SEVERITY: CRITICAL - Downloaded malware being executed

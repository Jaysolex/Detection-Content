// DETECTION: Registry Run Keys Modification
// MITRE: T1547.001 (Registry Run Keys / Startup Folder)

SecurityEvent
| where EventID == 4657
| where ObjectName has_any ("CurrentVersion\\Run", "CurrentVersion\\RunOnce")
| project TimeGenerated, Computer, Account, ObjectName, NewValue

// WHAT THIS DETECTS: Registry writes to Run/RunOnce keys
// SEVERITY: MEDIUM-HIGH - Persistence at logon

source="WinEventLog:Sysmon" EventCode=13 (TargetObject="*DisableRealtimeMonitoring*" OR TargetObject="*DisableAntiSpyware*" OR TargetObject="*DisableFirewall*" OR TargetObject="*DisableWindowsDefender*" OR TargetObject="*Run*" OR TargetObject="*Services*") (Image="*cmd.exe" OR Image="*powershell.exe" OR Image="*reg.exe") NOT User="SYSTEM"
| stats count by ComputerName, User, TargetObject
| where count > 0
